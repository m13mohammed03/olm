<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Accueil</a></li>
            <li class="breadcrumb-item"><a href="/shop" class="text-decoration-none">Boutique</a></li>
            <li class="breadcrumb-item active"><%= product.name %></li>
        </ol>
    </nav>

    <div class="row g-5">
        <div class="col-md-6">
            <img src="<%= product.image_url || 'https://via.placeholder.com/600x600?text=OLM+SUYARI' %>" class="img-fluid rounded shadow-sm" alt="<%= product.name %>">
        </div>
        <div class="col-md-6">
            <span class="badge bg-secondary mb-2"><%= product.category_name %></span>
            <h1 class="display-5 fw-bold mb-3"><%= product.name %></h1>
            <h3 class="text-primary mb-4"><%= Number(product.price).toFixed(0) %> F CFA</h3>
            
            <p class="lead mb-4"><%= product.description %></p>

            <div class="mb-4">
                <span class="fw-bold">Disponibilité:</span> 
                <% if (product.stock > 0) { %>
                    <span class="text-success"><i class="fas fa-check-circle"></i> En Stock (<%= product.stock %>)</span>
                <% } else { %>
                    <span class="text-danger"><i class="fas fa-times-circle"></i> Rupture de Stock</span>
                <% } %>
            </div>

            <form action="/cart/add" method="POST" class="d-flex align-items-center mb-4">
                <input type="hidden" name="product_id" value="<%= product.id %>">
                <div class="input-group me-3" style="width: 130px;">
                    <span class="input-group-text">Qté</span>
                    <input type="number" name="quantity" class="form-control text-center" value="1" min="1" max="<%= product.stock > 0 ? product.stock : 1 %>" <%= product.stock <= 0 ? 'disabled' : '' %>>
                </div>
                <button type="submit" class="btn btn-primary btn-lg px-5 rounded-pill flex-grow-1" <%= product.stock <= 0 ? 'disabled' : '' %>>
                    <i class="fas fa-shopping-cart me-2"></i> Ajouter au Panier
                </button>
            </form>
        </div>
    </div>
</div>
