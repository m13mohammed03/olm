<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title != 'undefined' ? title : 'OLM SUYARI' %></title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <!-- Header / Navbar -->
    <nav class="navbar navbar-expand-lg sticky-top py-3">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <% if (settings.site_logo) { %>
                    <img src="<%= settings.site_logo %>" alt="Logo" height="40" class="me-2">
                <% } else { %>
                    <i class="fas fa-gem text-primary me-2"></i> 
                <% } %>
                <span class="fw-bold fs-4"><%= settings.site_name || 'OLM SUYARI' %></span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item"><a class="nav-link" href="/">Accueil</a></li>
                    <li class="nav-item"><a class="nav-link" href="/shop">Boutique</a></li>
                    <li class="nav-item"><a class="nav-link" href="/about">À propos</a></li>
                    <li class="nav-item"><a class="nav-link" href="/contact">Contact</a></li>
                    
                    <li class="nav-item ms-3 position-relative">
                        <a class="nav-link" href="/cart">
                            <i class="fas fa-shopping-bag fa-lg text-primary"></i>
                            <% if (cartItemCount > 0) { %>
                                <span class="badge rounded-pill cart-badge"><%= cartItemCount %></span>
                            <% } %>
                        </a>
                    </li>

                    <% if (user) { %>
                        <li class="nav-item dropdown ms-3">
                            <a class="nav-link dropdown-toggle btn btn-outline-primary rounded-pill px-3 py-1" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user me-1"></i> <%= user.name %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <% if (user.role === 'admin') { %>
                                    <li><a class="dropdown-item" href="/admin">Tableau de bord</a></li>
                                <% } %>
                                <li><a class="dropdown-item" href="/orders">Mes Commandes</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="/auth/logout">Déconnexion</a></li>
                            </ul>
                        </li>
                    <% } else { %>
                        <li class="nav-item ms-3">
                            <a class="btn btn-outline-primary rounded-pill px-4" href="/auth/login">Connexion</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Flash Messages -->
    <div class="container mt-3">
        <% if (success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success alert-dismissible fade show">
                <%= success_msg %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>
        <% if (error_msg && error_msg.length > 0) { %>
            <div class="alert alert-danger alert-dismissible fade show">
                <%= error_msg %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>
    </div>

    <!-- Main Content -->
    <main>
        <%- body %>
    </main>

    <!-- Footer -->
    <footer class="mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h4><%= settings.site_name || 'OLM SUYARI' %></h4>
                    <p>Beauté de luxe, produits éclatants, maquillage et soins pour sublimer votre routine quotidienne.</p>
                </div>
                <div class="col-md-4 mb-4">
                    <h5>Liens Rapides</h5>
                    <ul class="list-unstyled">
                        <li><a href="/shop">Boutique</a></li>
                        <li><a href="/about">À propos de nous</a></li>
                        <li><a href="/contact">Contact</a></li>
                        <li><a href="/terms">Conditions Générales</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-4">
                    <h5>Newsletter</h5>
                    <p>Inscrivez-vous pour recevoir des offres spéciales et des mises à jour.</p>
                    <form class="d-flex">
                        <input type="email" class="form-control me-2" placeholder="Adresse Email">
                        <button class="btn btn-primary" type="button">S'abonner</button>
                    </form>
                </div>
            </div>
            <hr class="border-light mt-4 mb-3">
            <div class="text-center">
                <p class="mb-0">&copy; <%= new Date().getFullYear() %> <%= settings.site_name || 'OLM SUYARI' %>. Tous droits réservés.</p>
            </div>
        </div>
    </footer>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
