<div class="container py-5">
    <div class="row">
        <!-- Sidebar Filters -->
        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-4">Rechercher</h5>
                    <form action="/shop" method="GET" class="mb-4">
                        <div class="input-group">
                            <input type="text" name="search" class="form-control" placeholder="Rechercher des produits..." value="<%= typeof searchQuery != 'undefined' ? searchQuery : '' %>">
                            <button class="btn btn-primary" type="submit"><i class="fas fa-search"></i></button>
                        </div>
                    </form>

                    <h5 class="card-title mb-3">Catégories</h5>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item border-0 px-0">
                            <a href="/shop" class="text-decoration-none <%= !currentCategory ? 'fw-bold text-primary' : 'text-dark' %>">Tous les Produits</a>
                        </li>
                        <% categories.forEach(cat => { %>
                            <li class="list-group-item border-0 px-0">
                                <a href="/shop?category=<%= cat.id %>" class="text-decoration-none <%= currentCategory == cat.id ? 'fw-bold text-primary' : 'text-dark' %>">
                                    <%= cat.name %>
                                </a>
                            </li>
                        <% }) %>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Product Grid -->
        <div class="col-md-9">
            <h2 class="mb-4">Boutique</h2>
            <div class="row g-4">
                <% if (products.length === 0) { %>
                    <div class="col-12">
                        <div class="alert alert-info">Aucun produit trouvé.</div>
                    </div>
                <% } else { %>
                    <% products.forEach(product => { %>
                        <div class="col-md-4 col-sm-6">
                            <div class="card product-card h-100">
                                <img src="<%= product.image_url || 'https://via.placeholder.com/300x250?text=OLM+SUYARI' %>" class="card-img-top product-img" alt="<%= product.name %>">
                                <div class="card-body text-center">
                                    <h6 class="card-title text-truncate"><%= product.name %></h6>
                                    <p class="fw-bold mb-3"><%= Number(product.price).toFixed(0) %> F CFA</p>
                                    <a href="/product/<%= product.id %>" class="btn btn-outline-primary w-100 rounded-pill">Voir Détails</a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </div>
</div>
