<div class="container py-5">
    <h2 class="mb-4">Mes Commandes</h2>
    
    <% if (orders.length === 0) { %>
        <div class="alert alert-info text-center py-5">
            <i class="fas fa-box-open fa-3x mb-3 text-muted"></i>
            <h4>Aucune commande trouvée</h4>
            <p>Vous n'avez pas encore passé de commande.</p>
            <a href="/shop" class="btn btn-primary rounded-pill px-4 mt-2">Commencer vos Achats</a>
        </div>
    <% } else { %>
        <div class="table-responsive">
            <table class="table table-hover shadow-sm bg-white border rounded">
                <thead class="table-light">
                    <tr>
                        <th>ID Commande</th>
                        <th>Date</th>
                        <th>Statut</th>
                        <th>Montant Total</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% orders.forEach(order => { %>
                        <tr>
                            <td>#<%= order.id %></td>
                            <td><%= new Date(order.created_at).toLocaleDateString('fr-FR') %></td>
                            <td>
                                <% if (order.status === 'pending') { %>
                                    <span class="badge bg-warning text-dark">En Attente</span>
                                <% } else if (order.status === 'processing') { %>
                                    <span class="badge bg-info">En Traitement</span>
                                <% } else if (order.status === 'shipped') { %>
                                    <span class="badge bg-primary">Expédiée</span>
                                <% } else if (order.status === 'delivered') { %>
                                    <span class="badge bg-success">Livrée</span>
                                <% } else { %>
                                    <span class="badge bg-secondary"><%= order.status %></span>
                                <% } %>
                            </td>
                            <td><%= Number(order.total_amount).toFixed(0) %> F CFA</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary" disabled>Voir Détails</button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>
